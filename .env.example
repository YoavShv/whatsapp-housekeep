# Database (libsql / SQLite — local: file:./data/dev.db, Turso: libsql://...)
DATABASE_URL=file:./data/dev.db

# Anthropic — get key from console.anthropic.com
ANTHROPIC_API_KEY=

# Meta WhatsApp Cloud API — see README.md for setup instructions
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# Auth (NextAuth v5)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# POC single-tenant building (set in db:seed or use default)
POC_BUILDING_ID=building-001
POC_BUILDING_NAME=
