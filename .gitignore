# Serena MCP per-project cache/index/memories (regenerated on demand)
.serena/

# Local environment variables (may hold real tokens — never commit)
.env.local

# Self-improving doc-review hook artifacts (regenerated each session)
.claude/doc-review.md
.claude/.doc-review-state

# Python bytecode cache
__pycache__/

# Dependencies
node_modules/

# Next.js build output
.next/
next-env.d.ts

# TypeScript incremental build info
*.tsbuildinfo

# SQLite database files (created by db:migrate)
data/

# bun
bun.debug.*

# Non-bun lockfiles — this project uses bun only (see CLAUDE.md)
package-lock.json
pnpm-lock.yaml
yarn.lock
